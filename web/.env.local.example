# Copy this file to .env.local (already gitignored) and fill in real values.
# Without these two set, form submissions are still accepted and logged to
# .submissions/submissions.log, but no email is sent — useful for testing
# the form UX before real credentials exist.

# The Gmail account sending on behalf of the site.
GMAIL_USER=wepresentproject@gmail.com

# Generate at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Gmail account first).
GMAIL_APP_PASSWORD=

# Where submission notifications are sent. Defaults to GMAIL_USER's inbox
# (wepresentproject@gmail.com) if not set.
NOTIFY_EMAIL=wepresentproject@gmail.com
